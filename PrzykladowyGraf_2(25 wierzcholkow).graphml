            <data key="y">200.0</data>
            <data key="label">N</data>
        </node>
        <node id="n14">
            <data key="x">100.0</data>
            <data key="y">300.0</data>
            <data key="label">O</data>
        </node>
        <node id="n15">
            <data key="x">200.0</data>
            <data key="y">300.0</data>
            <data key="label">P</data>
        </node>
        <node id="n16">
            <data key="x">300.0</data>
            <data key="y">300.0</data>
            <data key="label">Q</data>
        </node>
        <node id="n17">
            <data key="x">400.0</data>
            <data key="y">300.0</data>
            <data key="label">R</data>
        </node>
        <node id="n18">
            <data key="x">500.0</data>
            <data key="y">300.0</data>
            <data key="label">S</data>
        </node>
        <node id="n19">
            <data key="x">600.0</data>
            <data key="y">300.0</data>
            <data key="label">T</data>
        </node>
        <node id="n20">
            <data key="x">700.0</data>
            <data key="y">300.0</data>
            <data key="label">U</data>
        </node>
        <node id="n21">
            <data key="x">100.0</data>
            <data key="y">400.0</data>
            <data key="label">V</data>
        </node>
        <node id="n22">
            <data key="x">200.0</data>
            <data key="y">400.0</data>
            <data key="label">W</data>
        </node>
        <node id="n23">
            <data key="x">300.0</data>
            <data key="y">400.0</data>
            <data key="label">X</data>
        </node>
        <node id="n24">
            <data key="x">400.0</data>
            <data key="y">400.0</data>
            <data key="label">Y</data>
        </node>

        <!-- Krawędzie -->
        <edge id="e0" source="n0" target="n1">
